# CreatorChain Environment Configuration

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creatorchain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=creatorchain

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Backend ---
PORT=4000
JWT_SECRET=your-jwt-secret-change-in-production
NODE_ENV=development

# --- Blockchain ---
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
PRIVATE_KEY=your-deployer-private-key
CREATOR_RIGHTS_ADDRESS=0x_deployed_contract_address
ROYALTY_DISTRIBUTOR_ADDRESS=0x_deployed_contract_address

# --- IPFS (Pinata) ---
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
PINATA_GATEWAY=https://gateway.pinata.cloud

# --- AI Service ---
AI_SERVICE_URL=http://localhost:5000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=CreatorChain
